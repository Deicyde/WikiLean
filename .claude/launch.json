{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "static-out",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8899", "--directory", "site/out"],
      "port": 8899
    },
    {
      "name": "wiki-dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "wiki", "--", "--port", "8787"],
      "port": 8787
    },
    {
      "name": "wiki-dev-devauth",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "wiki", "--", "--port", "8788", "--var", "AUTH_MODE:dev"],
      "port": 8788
    }
  ]
}
