/- ----- Z13822  (Q2741788)  [faithful] ----- -/
/-- Wikifunctions Z13822 "modular multiplicative inverse" вЂ” Wikidata Q2741788.
    Oracle: `ZMod.inv` (Mathlib.Data.ZMod.Basic), accessed as `((a : ZMod n)вЃ»В№).val`,
    the canonical residue `0 в‰¤ r < n` with `a * r в‰Ў 1 (mod n)` when `Nat.Coprime a n`.
    Computable (extended Euclidean algorithm via `Nat.gcdA`/`Nat.xgcd`). -/
def Z13822_spec (a n : в„•) : в„• := ((a : ZMod n)вЃ»В№).val

/-- The returned value is a genuine inverse modulo `n` whenever `a` is coprime to `n`. -/
example (a n : в„•) (h : Nat.Coprime a n) :
    (a : ZMod n) * (Z13822_spec a n : ZMod n) = 1 := by
  simpa [Z13822_spec] using ZMod.mul_val_inv (m := a) (n := n) h

/-- Sanity / decidability: for a positive modulus the residue is reduced. -/
example (a n : в„•) (hn : 0 < n) : Z13822_spec a n < n := by
  haveI : NeZero n := вџЁhn.ne'вџ©
  simpa [Z13822_spec] using ZMod.val_lt ((a : ZMod n)вЃ»В№)

-- Kernel-checkable example: 3вЃ»В№ mod 7 = 5  (since 3*5 = 15 в‰Ў 1 mod 7).
-- `decide` cannot reduce `ZMod.inv` (well-founded recursion via `Nat.gcdA`/`Nat.xgcd`),
-- so we pin the inverse by left-cancelling `3` against the two products that equal `1`.
example : Z13822_spec 3 7 = 5 := by
  show ((3 : ZMod 7)вЃ»В№).val = 5
  have h3 : (3 : ZMod 7) в‰  0 := by decide
  have hgcd : (3 : ZMod 7) * (3 : ZMod 7)вЃ»В№ = 1 :=
    ZMod.coe_mul_inv_eq_one 3 (by decide)
  have h5 : (3 : ZMod 7) * 5 = 1 := by decide
  have hval : ((5 : ZMod 7)).val = 5 := by decide
  haveI : Fact (Nat.Prime 7) := вџЁby norm_numвџ©
  have hinv : (3 : ZMod 7)вЃ»В№ = 5 := mul_left_cancelв‚Ђ h3 (by rw [hgcd, h5])
  rw [hinv, hval]

