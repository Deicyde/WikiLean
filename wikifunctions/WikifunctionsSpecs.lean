/- ----- Z35278  (Q204570)  [faithful] ----- -/
/- Wikifunctions Z35278 "Shannon entropy from string" вЂ” Wikidata Q204570.
   Signature: (String) в†’ float64.

   Shannon entropy of a string `s` is `H(s) = - в€‘_c p_c В· log_b p_c`, summed over
   distinct characters `c`, with `p_c = (count of c in s) / |s|` and base `b = 2`
   (bits вЂ” the conventional "entropy from string" return).

   OPERATIONAL oracle: assembled over IEEE-754 binary64 `Float`, so it is
   `#eval`-comparable to the live function. Mathematical IDEAL: the same sum over
   в„ќ using Mathlib's per-term `Real.negMulLog x = -x * log x` (nats) вЂ” Mathlib has
   no string/distribution-level Shannon entropy, so the oracle is assembled. -/
namespace Z35278

/-- Distinct characters of a string. -/
def chars (s : String) : List Char := s.toList.dedup

/-- Empirical probability of character `c` in string `s` (Float). -/
def probF (s : String) (c : Char) : Float :=
  (s.toList.count c).toFloat / s.toList.length.toFloat

/-- OPERATIONAL oracle: Shannon entropy in BITS over Float (what the WF returns).
    The `p == 0` guard encodes the `0В·log 0 = 0` convention. -/
def Z35278_spec (s : String) : Float :=
  (chars s).foldr
    (fun c acc =>
      let p := probF s c
      (if p == 0.0 then 0.0 else -p * (Float.log p / Float.log 2.0)) + acc) 0.0

-- Operational sanity (native eval):
#guard Float.abs (Z35278_spec "AB" - 1.0) < 1e-9      -- two equiprobable symbols в†’ 1 bit
#guard Float.abs (Z35278_spec "AAAA" - 0.0) < 1e-9    -- one symbol в†’ 0 bits

/-- Empirical probability of character `c` in string `s` (в„ќ, for the ideal). -/
noncomputable def prob (s : String) (c : Char) : в„ќ :=
  (s.toList.count c : в„ќ) / (s.toList.length : в„ќ)

/-- Mathematical ideal in NATS: the sum of Mathlib's `Real.negMulLog` over the
    empirical char distribution. -/
noncomputable def entropyNats (s : String) : в„ќ :=
  (chars s).foldr (fun c acc => Real.negMulLog (prob s c) + acc) 0

/-- Mathematical ideal in BITS (matching the Float oracle's convention). -/
noncomputable def entropyBits (s : String) : в„ќ :=
  (chars s).foldr (fun c acc => -(prob s c) * Real.logb 2 (prob s c) + acc) 0

/-- Bits and nats ideals differ only by the base-conversion factor `log 2`. This
    pins the WF's bits value to the Mathlib `negMulLog`-based nats value. -/
example (s : String) : entropyBits s = entropyNats s / Real.log 2 := by
  unfold entropyBits entropyNats
  induction chars s with
  | nil => simp
  | cons c cs ih =>
    rw [List.foldr_cons, List.foldr_cons, ih, add_div]
    congr 1
    rw [Real.negMulLog, Real.logb]
    ring

end Z35278

