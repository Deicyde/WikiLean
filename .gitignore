.DS_Store
*.log
.env
.env.*
!.env.example

# Python
__pycache__/
*.py[cod]
.venv/
venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/

# Node
node_modules/
dist/
build/
.next/

# Lean
.lake/
lake-packages/
build/

# Editor
.vscode/
.idea/
*.swp

# WikiLean
catalog/data/.cache/
# Local Wikidata embedding index — regenerable from wikidata_universe.jsonl by
# catalog/build_wikidata_embeddings.py (like other derived data). ~18MB matrix.
catalog/data/wikidata_embeddings.npz
catalog/data/wikidata_embeddings.meta.jsonl
.wrangler/
# Collaboration outreach drafts — kept local, NOT for the public repo yet (Jack's
# call, 2026-07-02). The repo is public; these are unsent drafts to named people.
# Remove this line to publish when ready.
docs/outreach.md
# Cached Wikipedia HTML (351 MB) and derived section extracts are re-fetchable
# by pinned revid — but the *.meta.json revid sidecars are NOT reproducible
# (they record which revision each article was annotated against), so keep them.
site/cache/*
!site/cache/*.meta.json
site/out/

# TheoremGraph match CSV cache (108MB; re-download via ingest_theorem_graph.py --download)
catalog/.cache/

# v2 graph rebuild — large derived artifacts (regenerate via build_graph_v2.py
# from rebuild_grounding.json + the math-graph dep cache). The grounding itself
# (the expensive agent output) IS committed.
catalog/data/concept_graph_v2.json
catalog/data/concept_graph_v2_viz.json
catalog/data/decl_to_qid_v2.json
catalog/data/formal_edges_lifted.json

# BRAIN derived artifacts — rebuild in seconds from committed inputs:
# rollups via brain/build_rollups.py (needs catalog/.cache CSVs, see brain/README.md);
# shards via brain/build_shards.py (from the committed brain/data/nodes+edges).
brain/data/rollup_edges.file.jsonl
brain/data/rollup_edges.dir.jsonl
site/assets/brain/
brain/data/rollup_edges.tree.jsonl
# module rollup is derived like its file/dir/tree siblings above (build_rollups.py)
brain/data/rollup_edges.module.jsonl
# links-kind edges (371k rows, ~76MB — GitHub's 100MB file limit forbids the
# joint file); rebuilt deterministically by brain/build_edges.py from the
# committed catalog/data/external/ inputs. Non-links edges.jsonl stays tracked.
brain/data/edges_links.jsonl
# brain-nightly cadence stamps + lock dir (its *.log files are covered above)
site/ops/logs/

# Control-plane worklists — regenerated by manage/refresh.py + status.py (centrality
# × coverage → worklists). Local state, not source. (decl_sweep_proposal.json is kept
# tracked until its sweep is applied.)
manage/data/centrality.json
manage/data/coverage.json
manage/data/moderation_worklist.json
manage/data/pipeline_worklist.json
manage/data/rebuild_targets.json
manage/data/digest.json
manage/data/formalize_slugs.txt

# catalog derived outputs — regenerable from committed inputs by their builders
catalog/data/join_fabric.jsonl
catalog/data/join_fabric.tsv
catalog/data/module_frequency.csv
catalog/data/annotation_summary.csv
catalog/mathlib_deps/decl_review_queue.csv

# Wikifunctions derived data (build_join.py / build_specs.py); the hand-verified
# corpus wikifunctions_specs_verified.jsonl stays tracked.
wikifunctions/data/wikifunctions_universe.jsonl
wikifunctions/data/wikifunctions_join_summary.json

# W3C Web-Annotation export tree — a derived export nothing in the repo consumes.
site/out_w3c/

# Agent-draft annotations — the intermediate *.agent1.json drafts (the D1 seed
# keeps only the richest slug and discards these). The canonical re-anchored
# *.json backups stay tracked.
site/annotations/*.agent1.json
