# WikiLean nightly tunables — edit the numbers, save, done. The next run (03:00
# launchd, or `bash site/ops/run-now.sh`) picks them up. No code changes needed.
#
# Sourced by nightly-moderate.sh. Values use ":=" (assign-only-if-unset), so a
# one-off env override still wins, e.g.:
#   WIKILEAN_FORMALIZE_LIMIT=25 bash site/ops/run-now.sh
# To pause the formalize step entirely, set the limit to 0.

# --- Formalize backlog ---------------------------------------------------------
# Agent-2 the extracted (Agent-1-only) articles the manage/ control plane finds
# but the /api/work ladder can't see. The backlog is finite (~25 as of
# 2026-07-01); RAISE to drain faster, 0 to pause. Rough cost ~20-90k tokens per
# article. NB: FORMALIZE_BUDGET is the real governor — LIMIT is only the article
# cap, so the run stops at whichever binds first. LIMIT raised 12->25 so the whole
# verified backlog is eligible; BUDGET bumped 600k->800k drains ~14-16/night
# (~2 nights to clear). Raise BUDGET further to finish in one night.
: "${WIKILEAN_FORMALIZE_LIMIT:=25}"
: "${WIKILEAN_FORMALIZE_BUDGET:=800000}"
export WIKILEAN_FORMALIZE_LIMIT WIKILEAN_FORMALIZE_BUDGET

# --- Concept graph nightly refresh --------------------------------------------
# After moderation, rebuild the /graph data so it reflects current Mathlib
# coverage (verified @[wikidata] nodes + live per-node formalization coverage)
# and push it to KV. The Worker serves /graph_data.json from KV, so this is a
# `wrangler kv put` — NOT a Worker deploy (never ships wiki/src). REFRESH=0 skips
# the whole step; DEPLOY=0 rebuilds the data but skips the KV push.
: "${WIKILEAN_GRAPH_REFRESH:=1}"; export WIKILEAN_GRAPH_REFRESH
: "${WIKILEAN_GRAPH_DEPLOY:=1}";  export WIKILEAN_GRAPH_DEPLOY
# /decl/:name reverse-citation refresh (KV declcites:v1) — independent of the
# graph gate; GRAPH_DEPLOY=0 still skips its KV push.
: "${WIKILEAN_DECLCITES_REFRESH:=1}"; export WIKILEAN_DECLCITES_REFRESH

# --- Propose-then-approve generation (ON since 2026-07-02, Jack's call) --------
# Agent 2's review pass may attach SEARCH-VERIFIED proposals to human-owned
# annotations; they land in the /proposals queue for patroller/admin decision
# (the AI never applies them — findLostHuman stays the floor). NB: turning this
# on/off changes prompt_sha (a deliberate research-cohort boundary). 0 disables.
: "${WIKILEAN_PROPOSALS:=1}"; export WIKILEAN_PROPOSALS

# --- General review / drift (uncomment any line to override the script default) -
# : "${WIKILEAN_REVIEW_LIMIT:=15}";      export WIKILEAN_REVIEW_LIMIT
# : "${WIKILEAN_BUDGET_TOKENS:=700000}"; export WIKILEAN_BUDGET_TOKENS
# : "${WIKILEAN_WPUPDATE_LIMIT:=300}";   export WIKILEAN_WPUPDATE_LIMIT

# --- NEW-article tagging (org.wikilean.newtags @ 03:10, newtags-nightly.sh) ----
# Fetches Agent-1+Agent-2 (Mathlib) annotations for not-yet-in-D1 articles from a
# curated candidate list and CREATES them on the live site. Runs on SONNET by
# default for higher Max throughput than the opus review cohort. IMPORTANT: the
# model is a NEWTAGS-only var (WIKILEAN_NEWTAGS_MODEL) — this file is ALSO sourced
# by the 03:20 moderation job, so it must NOT export the raw WIKILEAN_AGENT_MODEL
# that batch_annotate reads, or moderation would silently drop its pinned-opus
# cohort. newtags-nightly.sh maps WIKILEAN_NEWTAGS_MODEL -> WIKILEAN_AGENT_MODEL
# only inside its own process. The newtags job uses its OWN lock, so it coexists
# with the 03:20 moderation job (both share the Max 5-hour window; the rate-limit
# retry smooths contention). Nightly agent spend for this job is about
# WIKILEAN_NEWTAGS_BUDGET. LIMIT caps articles/night; 0 pauses (the script also
# no-ops on an empty/absent candidate file). Point CANDS at a different JSONL
# ({title,slug,source} per line) to tag a different set.
: "${WIKILEAN_NEWTAGS_MODEL:=claude-sonnet-5}";    export WIKILEAN_NEWTAGS_MODEL
: "${WIKILEAN_NEWTAGS_LIMIT:=40}";                 export WIKILEAN_NEWTAGS_LIMIT
: "${WIKILEAN_NEWTAGS_CONCURRENCY:=6}";            export WIKILEAN_NEWTAGS_CONCURRENCY
: "${WIKILEAN_NEWTAGS_BUDGET:=2000000}";           export WIKILEAN_NEWTAGS_BUDGET
: "${WIKILEAN_NEWTAGS_CANDS:=/Users/jack/Desktop/LEAN/WikiLean/site/data/new-candidates-cs.jsonl}"
export WIKILEAN_NEWTAGS_CANDS

# --- BRAIN nightly refresh (org.wikilean.brain @ 02:20, brain-nightly.sh) ------
# Ingest external DBs (per-source cadence stamps in site/ops/logs/) → agent team
# (propose-only) → fold_proposals → rebuild nodes/edges → acceptance gate →
# shards → clean-tree-gated deploy. Logs: site/ops/logs/brain-<ts>.log.
# REFRESH=0 skips the whole job. AGENTS=1 enables the SDK agent team
# (cartographer + skeptic; writes brain/proposals/*.jsonl ONLY —
# fold_proposals.py stays the only gate into brain/data) — OFF until Jack flips
# it. AGENT_BUDGET caps the team's nightly tokens (rides the shared Max window
# with the 03:10/03:20 jobs). DEPLOY=1 lets the job ship rebuilt shards via
# `npm run deploy` — ONLY when `git status --porcelain -- wiki/src
# wiki/package.json wiki/wrangler.jsonc` is empty AND `npx tsc --noEmit` passes
# (never ships uncommitted Worker WIP) — OFF until Jack flips it.
: "${WIKILEAN_BRAIN_REFRESH:=1}";           export WIKILEAN_BRAIN_REFRESH
: "${WIKILEAN_BRAIN_AGENTS:=0}";            export WIKILEAN_BRAIN_AGENTS
: "${WIKILEAN_BRAIN_AGENT_BUDGET:=500000}"; export WIKILEAN_BRAIN_AGENT_BUDGET
: "${WIKILEAN_BRAIN_DEPLOY:=0}";            export WIKILEAN_BRAIN_DEPLOY
# Agent model for brain/sync_agents.py ONLY — deliberately not the raw
# WIKILEAN_AGENT_MODEL (same isolation rationale as WIKILEAN_NEWTAGS_MODEL:
# this file is sourced by the moderation job too).
: "${WIKILEAN_BRAIN_AGENT_MODEL:=claude-sonnet-5}"; export WIKILEAN_BRAIN_AGENT_MODEL
# Per-run fetch caps for the polite monthly crawlers (read by the ingest
# adapters; Kerodon has ~7.5k tags, DLMF ~600 section pages — the caps bound a
# single night's requests, the adapters resume from cache next run) and the
# per-source ext-node minting cap (brain/SCHEMA.md minting policy, default
# 8000/db; read by the brain build).
: "${KERODON_MAX_FETCH:=800}";   export KERODON_MAX_FETCH
: "${DLMF_MAX_FETCH:=700}";      export DLMF_MAX_FETCH
: "${BRAIN_EXT_NODE_CAP:=32000}"; export BRAIN_EXT_NODE_CAP
# 32000 = effectively uncapped for anchored+1-hop minting (nlab peaked at
# 13,556 candidates, proofwiki at 26,023 — the 8,000 cap was silently hiding
# most of their internal-link graphs, Jack bug report 2026-07-10)
