# WikiLean nightly tunables — edit the numbers, save, done. The next run (03:00
# launchd, or `bash site/ops/run-now.sh`) picks them up. No code changes needed.
#
# Sourced by nightly-moderate.sh. Values use ":=" (assign-only-if-unset), so a
# one-off env override still wins, e.g.:
#   WIKILEAN_FORMALIZE_LIMIT=25 bash site/ops/run-now.sh
# To pause the formalize step entirely, set the limit to 0.

# --- Formalize backlog ---------------------------------------------------------
# Agent-2 the extracted (Agent-1-only) articles the manage/ control plane finds
# but the /api/work ladder can't see. The backlog is finite (~25 as of
# 2026-07-01); RAISE to drain faster, 0 to pause. Rough cost ~20-90k tokens per
# article. NB: FORMALIZE_BUDGET is the real governor — LIMIT is only the article
# cap, so the run stops at whichever binds first. LIMIT raised 12->25 so the whole
# verified backlog is eligible; BUDGET bumped 600k->800k drains ~14-16/night
# (~2 nights to clear). Raise BUDGET further to finish in one night.
: "${WIKILEAN_FORMALIZE_LIMIT:=25}"
: "${WIKILEAN_FORMALIZE_BUDGET:=800000}"
export WIKILEAN_FORMALIZE_LIMIT WIKILEAN_FORMALIZE_BUDGET

# --- Concept graph nightly refresh --------------------------------------------
# After moderation, rebuild the /graph data so it reflects current Mathlib
# coverage (verified @[wikidata] nodes + live per-node formalization coverage)
# and push it to KV. The Worker serves /graph_data.json from KV, so this is a
# `wrangler kv put` — NOT a Worker deploy (never ships wiki/src). REFRESH=0 skips
# the whole step; DEPLOY=0 rebuilds the data but skips the KV push.
: "${WIKILEAN_GRAPH_REFRESH:=1}"; export WIKILEAN_GRAPH_REFRESH
: "${WIKILEAN_GRAPH_DEPLOY:=1}";  export WIKILEAN_GRAPH_DEPLOY
# /decl/:name reverse-citation refresh (KV declcites:v1) — independent of the
# graph gate; GRAPH_DEPLOY=0 still skips its KV push.
: "${WIKILEAN_DECLCITES_REFRESH:=1}"; export WIKILEAN_DECLCITES_REFRESH

# --- Propose-then-approve generation (ON since 2026-07-02, Jack's call) --------
# Agent 2's review pass may attach SEARCH-VERIFIED proposals to human-owned
# annotations; they land in the /proposals queue for patroller/admin decision
# (the AI never applies them — findLostHuman stays the floor). NB: turning this
# on/off changes prompt_sha (a deliberate research-cohort boundary). 0 disables.
: "${WIKILEAN_PROPOSALS:=1}"; export WIKILEAN_PROPOSALS

# --- General review / drift (uncomment any line to override the script default) -
# : "${WIKILEAN_REVIEW_LIMIT:=15}";      export WIKILEAN_REVIEW_LIMIT
# : "${WIKILEAN_BUDGET_TOKENS:=700000}"; export WIKILEAN_BUDGET_TOKENS
# : "${WIKILEAN_WPUPDATE_LIMIT:=300}";   export WIKILEAN_WPUPDATE_LIMIT
