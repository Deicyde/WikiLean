      "kind": "definition",
      "label": "Hexadecimal",
      "anchor": {
        "section": "(Lead)",
        "snippet": "Hexadecimal ( hex for short) is a positional numeral system for representing a numeric value as base 16."
      },
      "status": "partial",
      "mathlib": {
        "decl": "Nat.digits",
        "module": "Mathlib.Data.Nat.Digits.Defs",
        "match_kind": "generalization"
      },
      "note": "Mathlib's `Nat.digits` defines positional digit expansion for any base ≥ 2, which specializes to base 16, but no hexadecimal-specific definition exists.",
      "provenance": "ai"
    },
    {
