    {
      "kind": "definition",
      "label": "Flat module",
      "anchor": {
        "section": "(Lead)",
        "snippet": "a module M over a ring R is flat if taking the tensor product over R with M preserves exact sequences"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "definition",
      "label": "Faithfully flat module",
      "anchor": {
        "section": "(Lead)",
        "snippet": "A module is faithfully flat if taking the tensor product with a sequence produces an exact sequence if and only if the original sequence is exact"
      },
      "provenance": "ai-agent1"
    },
