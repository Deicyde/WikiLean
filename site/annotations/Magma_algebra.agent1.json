    },
    {
      "kind": "definition",
      "label": "Flexible",
      "anchor": {
        "section": "Classification by properties",
        "snippet": "if xy • x ≡ x • yx"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "definition",
      "label": "Associative (semigroup)",
      "anchor": {
        "section": "Classification by properties",
