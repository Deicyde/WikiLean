  "annotations": [
    {
      "kind": "definition",
      "label": "Homeomorphism",
      "anchor": {
        "section": "(Lead)",
        "snippet": "is a bijective and continuous function between topological spaces that has a continuous inverse function"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "definition",
      "label": "Homeomorphic spaces",
      "anchor": {
        "section": "(Lead)",
        "snippet": "Two spaces with a homeomorphism between them are called homeomorphic"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "definition",
      "label": "Homeomorphism (formal)",
      "anchor": {
        "section": "Definition",
        "snippet": "is a homeomorphism if it has the following properties"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "definition",
      "label": "Self-homeomorphism",
      "anchor": {
        "section": "Definition",
        "snippet": "A self-homeomorphism is a homeomorphism from a topological space onto itself"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "definition",
      "label": "Homeomorphism classes",
      "anchor": {
        "section": "Definition",
        "snippet": "Its equivalence classes are called homeomorphism classes"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "example",
      "label": "Necessity of continuous inverse",
      "anchor": {
        "section": "Definition",
        "snippet": "The third requirement, that"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "definition",
      "label": "Homeomorphism group",
      "anchor": {
        "section": "Definition",
        "snippet": "forms a group , called the homeomorphism group of X"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "example",
      "label": "Open interval homeomorphic to reals",
      "anchor": {
        "section": "Examples",
        "snippet": "is homeomorphic to the real numbers"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "example",
      "label": "Closed disk homeomorphic to square",
      "anchor": {
        "section": "Examples",
        "snippet": "and the square"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "example",
      "label": "Graph of differentiable function",
      "anchor": {
        "section": "Examples",
        "snippet": "The graph of a differentiable function is homeomorphic to the domain of the function"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "example",
      "label": "Differentiable parametrization of a curve",
      "anchor": {
        "section": "Examples",
        "snippet": "A differentiable parametrization of a curve is a homeomorphism between the domain of the parametrization and the curve"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "example",
      "label": "Chart of a manifold",
      "anchor": {
        "section": "Examples",
        "snippet": "A chart of a manifold is a homeomorphism between an open subset of the manifold and an open subset of a Euclidean space"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "example",
      "label": "Stereographic projection",
      "anchor": {
        "section": "Examples",
        "snippet": "The stereographic projection is a homeomorphism between the unit sphere"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "example",
      "label": "Topological group operations",
      "anchor": {
        "section": "Examples",
        "snippet": "is a topological group , its inversion map"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "example",
      "label": "R^m not homeomorphic to R^n",
      "anchor": {
        "section": "Counter-examples",
        "snippet": "are not homeomorphic for m ≠ n"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "example",
      "label": "Real line vs unit circle",
      "anchor": {
        "section": "Counter-examples",
        "snippet": "The Euclidean real line is not homeomorphic to the unit circle"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "example",
      "label": "Intervals not homeomorphic",
      "anchor": {
        "section": "Counter-examples",
        "snippet": "The one-dimensional intervals"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "proposition",
      "label": "Homeomorphic spaces share topological properties",
      "anchor": {
        "section": "Properties",
        "snippet": "Two homeomorphic spaces share the same topological properties"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "proposition",
      "label": "Homeomorphism is open and closed",
      "anchor": {
        "section": "Properties",
        "snippet": "A homeomorphism is simultaneously an open mapping and a closed mapping"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "theorem",
      "label": "Alexander's trick",
      "anchor": {
        "section": "Properties",
        "snippet": "can be extended to a self-homeomorphism of the whole disk"
      },
      "provenance": "ai-agent1"
    }
  ]
