    },
    {
      "kind": "definition",
      "label": "Injection",
      "anchor": {
        "section": "Injection",
        "snippet": "A function is injective ( one-to-one ) if each possible element of the codomain is mapped to by at most one argument."
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "proposition",
      "label": "Injective iff left-invertible",
      "anchor": {
        "section": "Injection",
        "snippet": "is left- invertible"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "proposition",
      "label": "Injection induces bijection onto image",
      "anchor": {
        "section": "Injection",
        "snippet": "every injection induces a bijection onto its image"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "proposition",
      "label": "Composition of injections is injective",
      "anchor": {
        "section": "Injection",
        "snippet": "The composition of two injections is again an injection"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "proposition",
      "label": "Every embedding is injective",
      "anchor": {
        "section": "Injection",
        "snippet": "Every embedding is injective."
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "definition",
      "label": "Surjection",
      "anchor": {
        "section": "Surjection",
        "snippet": "A function is surjective or onto if each element of the codomain is mapped to by at least one element of the domain"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "proposition",
      "label": "Surjective iff right-invertible",
      "anchor": {
        "section": "Surjection",
        "snippet": "is surjective if and only if it is right-invertible"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "proposition",
      "label": "Surjection induces bijection from quotient",
      "anchor": {
        "section": "Surjection",
        "snippet": "every surjection induces a bijection from a quotient set of its domain to its codomain"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "proposition",
      "label": "Composition of surjections is surjective",
      "anchor": {
        "section": "Surjection",
        "snippet": "The composition of two surjections is again a surjection"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "definition",
      "label": "Bijection",
      "anchor": {
        "section": "Bijection",
        "snippet": "A function is bijective if it is both injective and surjective."
