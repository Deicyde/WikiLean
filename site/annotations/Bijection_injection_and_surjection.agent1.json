  "annotations": [
    {
      "kind": "definition",
      "label": "Injective function (informal)",
      "anchor": {
        "section": "(Lead)",
        "snippet": "The function is injective , or one-to-one , if each element of the codomain is mapped to by at most one element of the domain"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "definition",
      "label": "Surjective function (informal)",
      "anchor": {
        "section": "(Lead)",
        "snippet": "The function is surjective , or onto , if each element of the codomain is mapped to by at least one element of the domain"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "definition",
      "label": "Bijective function (informal)",
      "anchor": {
        "section": "(Lead)",
        "snippet": "The function is bijective ( one-to-one and onto , one-to-one correspondence , or invertible ) if each element of the codomain is mapped to by exactly one element of the domain"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "proposition",
      "label": "Relation holding for any function",
      "anchor": {
