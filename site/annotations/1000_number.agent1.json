    {
      "kind": "definition",
      "label": "Definition of 1000",
      "anchor": {
        "section": "(Lead)",
        "snippet": "1000 or one thousand is the natural number following 999 and preceding 1001"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "definition",
      "label": "Chiliad",
      "anchor": {
        "section": "(Lead)",
        "snippet": "A group of one thousand units is sometimes known, from Ancient Greek , as a chiliad"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "definition",
      "label": "Millennium",
      "anchor": {
        "section": "(Lead)",
        "snippet": "A period of one thousand years may be known as a chiliad or, more often from Latin , as a millennium"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "definition",
      "label": "Short thousand / long thousand",
      "anchor": {
        "section": "(Lead)",
        "snippet": "described as a short thousand in medieval contexts where it is necessary to distinguish the Germanic concept of 1200 as a long thousand"
      },
      "provenance": "ai-agent1"
    },
    {
