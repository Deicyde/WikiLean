    {
      "kind": "definition",
      "label": "Concrete category (informal)",
      "anchor": {
        "section": "(Lead)",
        "snippet": "a concrete category is a category that is equipped with a faithful functor to the category of sets"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "definition",
      "label": "Concrete category (elementary form)",
      "anchor": {
        "section": "(Lead)",
        "snippet": "consists of a class of objects , each equipped with an underlying set"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "definition",
      "label": "Concrete category (formal)",
      "anchor": {
        "section": "Definition",
        "snippet": "A concrete category is a pair"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "definition",
      "label": "Forgetful functor interpretation",
      "anchor": {
        "section": "Definition",
        "snippet": "The functor U can often be thought of as a forgetful functor"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "definition",
      "label": "Homomorphisms in a concrete category",
      "anchor": {
        "section": "Definition",
        "snippet": "It is customary to call the morphisms in a concrete category homomorphisms"
