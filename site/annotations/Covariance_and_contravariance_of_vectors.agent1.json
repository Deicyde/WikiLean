{
  "slug": "Covariance_and_contravariance_of_vectors",
  "wikipedia_title": "Covariance and contravariance of vectors",
  "display_title": "Covariance and contravariance of vectors",
  "schema_version": 3,
  "annotations": [
    {
      "kind": "definition",
      "label": "Covariance and contravariance",
      "anchor": {
        "section": "(Lead)",
        "snippet": "describe how the quantitative description of certain geometric or physical entities changes with a change of basis"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "definition",
      "label": "Contravariant vs covariant vector",
      "anchor": {
        "section": "(Lead)",
        "snippet": "a contravariant vector is a list of numbers that transforms oppositely to a change of basis"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "definition",
      "label": "Vector as contravariant tensor",
      "anchor": {
        "section": "Introduction",
        "snippet": "has components that transform inversely to the transformation of the reference axes"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "definition",
      "label": "Covector",
      "anchor": {
        "section": "Introduction",
        "snippet": "a covector has components that transform like the reference axes"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "definition",
      "label": "Scalar (invariant)",
      "anchor": {
        "section": "Introduction",
        "snippet": "is an object that does not vary with the change in basis"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "definition",
      "label": "Duality pairing",
      "anchor": {
        "section": "Introduction",
        "snippet": "It is the duality pairing of vectors and covectors"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "definition",
      "label": "Change of basis transformation",
      "anchor": {
        "section": "Definition",
        "snippet": "refers to how the components of a coordinate vector transform under a change of basis"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "definition",
      "label": "Components of a vector in a basis",
      "anchor": {
        "section": "Contravariant transformation",
        "snippet": "known as the components of v in the f basis"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "proposition",
      "label": "Contravariant transformation rule",
      "anchor": {
        "section": "Contravariant transformation",
        "snippet": "these components are said to transform contravariantly under a change of basis"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "definition",
      "label": "Linear functional components",
      "anchor": {
        "section": "Covariant transformation",
        "snippet": "A linear functional α on V is expressed uniquely in terms of its components"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "proposition",
      "label": "Covariant transformation rule",
      "anchor": {
        "section": "Covariant transformation",
        "snippet": "these components are said to transform covariantly under a change of basis"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "definition",
      "label": "Coordinate functions",
      "anchor": {
        "section": "Coordinates",
        "snippet": "defines uniquely a set of coordinate functions on V"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "definition",
      "label": "Contravariant vector (transforms like coordinates)",
      "anchor": {
        "section": "Coordinates",
        "snippet": "defines a contravariant vector (or simply vector)"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "definition",
      "label": "Covariant vector (covector)",
      "anchor": {
        "section": "Coordinates",
        "snippet": "is then a covariant vector (or covector)"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "proposition",
      "label": "Frame related by inverse Jacobian",
      "anchor": {
        "section": "Coordinates",
        "snippet": "is related to the frame f by the inverse of the Jacobian matrix of the coordinate transition"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "definition",
      "label": "Tangent vector",
      "anchor": {
        "section": "Coordinates",
        "snippet": "A tangent vector is by definition a vector that is a linear combination of the coordinate partials"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "definition",
      "label": "Contravariant vector on a manifold",
      "anchor": {
        "section": "Coordinates",
        "snippet": "transform in this way on passing from one coordinate system to another is called a contravariant vector"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "proposition",
      "label": "Metric identifies vectors with covectors",
      "anchor": {
        "section": "Covariant and contravariant components of a vector with a metric",
        "snippet": "because the bilinear form allows covectors to be identified with vectors"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "definition",
      "label": "Reciprocal basis",
      "anchor": {
        "section": "Covariant and contravariant components of a vector with a metric",
        "snippet": "there is a unique reciprocal basis"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "definition",
      "label": "Contravariant and covariant components",
      "anchor": {
        "section": "Covariant and contravariant components of a vector with a metric",
        "snippet": "are the contravariant components of the vector v in the basis f"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "definition",
      "label": "Dual basis in Euclidean plane",
      "anchor": {
        "section": "Euclidean plane",
        "snippet": "the dot product allows for vectors to be identified with covectors"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "proposition",
      "label": "Dual basis perpendicularity",
      "anchor": {
        "section": "Euclidean plane",
        "snippet": "are perpendicular to each other"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "example",
      "label": "Dual basis of a 45° pair",
      "anchor": {
        "section": "Example",
        "snippet": "consisting of a pair of vectors making a 45° angle with one another"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "definition",
      "label": "Dual basis in 3D Euclidean space",
      "anchor": {
        "section": "Three-dimensional Euclidean space",
        "snippet": "one can also determine explicitly the dual basis to a given set of basis vectors"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "proposition",
      "label": "Mutually reciprocal bases",
      "anchor": {
        "section": "Three-dimensional Euclidean space",
        "snippet": "they are still mutually reciprocal"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "proposition",
      "label": "Contravariant components via dot product",
      "anchor": {
        "section": "Three-dimensional Euclidean space",
        "snippet": "the contravariant components of any vector v can be obtained by the dot product of v with the dual basis vectors"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "proposition",
      "label": "Covariant components via dot product",
      "anchor": {
        "section": "Three-dimensional Euclidean space",
        "snippet": "the covariant components of v can be obtained from the dot product of v with basis vectors"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "proposition",
      "label": "Orthonormal basis equals dual basis",
      "anchor": {
        "section": "Three-dimensional Euclidean space",
        "snippet": "If the basis vectors are orthonormal , then they are the same as the dual basis vectors"
      },
      "provenance": "ai-agent1"
