  "annotations": [
    {
      "kind": "definition",
      "label": "Surjective function",
      "anchor": {
        "section": "Definition",
        "snippet": "A surjective function is a function whose image is equal to its codomain"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "example",
      "label": "Identity function is surjective",
      "anchor": {
        "section": "Examples",
        "snippet": "the identity function id X on X is surjective"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "example",
      "label": "Parity map onto {0,1}",
      "anchor": {
        "section": "Examples",
        "snippet": "even integers are mapped to 0 and odd integers to 1"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "example",
      "label": "Affine map 2x+1 is surjective",
      "anchor": {
        "section": "Examples",
        "snippet": "because for every real number y"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "example",
      "label": "Cubic x^3-3x is surjective not injective",
      "anchor": {
        "section": "Examples",
        "snippet": "every cubic polynomial with real coefficients has at least one real root"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "example",
      "label": "Square map not surjective on R",
      "anchor": {
        "section": "Examples",
        "snippet": "since there is no real number x such that"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "example",
      "label": "Natural logarithm is surjective",
      "anchor": {
        "section": "Examples",
        "snippet": "The natural logarithm function"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "example",
      "label": "Matrix exponential surjectivity",
      "anchor": {
        "section": "Examples",
        "snippet": "The matrix exponential is not surjective when seen as a map"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "example",
      "label": "Projection from a product is surjective",
      "anchor": {
        "section": "Examples",
        "snippet": "The projection from a cartesian product"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "example",
      "label": "3D-to-2D screen projection",
      "anchor": {
        "section": "Examples",
        "snippet": "vectors are projected onto a 2D flat screen"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "proposition",
      "label": "Bijective iff surjective and injective",
      "anchor": {
        "section": "Properties",
        "snippet": "A function is bijective if and only if it is both surjective and injective"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "proposition",
      "label": "Surjectivity is a property of the mapping",
      "anchor": {
        "section": "Properties",
        "snippet": "surjectivity is not a property of the function itself, but rather a property of the mapping"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "definition",
      "label": "Right inverse of a function",
      "anchor": {
        "section": "Surjections as right invertible functions",
        "snippet": "is said to be a right inverse of the function"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "theorem",
      "label": "Right inverse iff surjection (axiom of choice)",
      "anchor": {
        "section": "Surjections as right invertible functions",
        "snippet": "Every function with a right inverse is necessarily a surjection"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "proposition",
      "label": "Recovering a subset from its preimage",
      "anchor": {
        "section": "Surjections as right invertible functions",
        "snippet": "Thus, B can be recovered from its preimage"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "example",
      "label": "Right inverse illustration",
      "anchor": {
        "section": "Surjections as right invertible functions",
        "snippet": "in the first illustration in the gallery"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "theorem",
      "label": "Surjective iff right-cancellative",
      "anchor": {
        "section": "Surjections as epimorphisms",
        "snippet": "is surjective if and only if it is right-cancellative"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "proposition",
      "label": "Surjections are epimorphisms in Set",
      "anchor": {
        "section": "Surjections as epimorphisms",
        "snippet": "surjective functions are precisely the epimorphisms in the category of sets"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "proposition",
      "label": "Right inverse implies epimorphism",
      "anchor": {
        "section": "Surjections as epimorphisms",
        "snippet": "Any morphism with a right inverse is an epimorphism"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "definition",
      "label": "Section of a morphism",
      "anchor": {
        "section": "Surjections as epimorphisms",
        "snippet": "is called a section of f"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "definition",
      "label": "Split epimorphism",
      "anchor": {
        "section": "Surjections as epimorphisms",
        "snippet": "is called a split epimorphism"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "definition",
      "label": "Surjection as a binary relation",
      "anchor": {
        "section": "Surjections as binary relations",
        "snippet": "is then a binary relation between X and Y that is right-unique and both left-total and right-total"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "theorem",
      "label": "Cardinality of domain dominates codomain",
      "anchor": {
        "section": "Cardinality of the domain of a surjection",
        "snippet": "The cardinality of the domain of a surjective function is greater than or equal to the cardinality of its codomain"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "proposition",
      "label": "Finite equal-size: surjective iff injective",
      "anchor": {
        "section": "Cardinality of the domain of a surjection",
        "snippet": "if both X and Y are finite with the same number of elements"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "proposition",
      "label": "Composition of surjections is surjective",
      "anchor": {
        "section": "Composition and decomposition",
        "snippet": "The composition of surjective functions is always surjective"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "theorem",
      "label": "Surjection-injection decomposition",
      "anchor": {
        "section": "Composition and decomposition",
        "snippet": "Any function can be decomposed into a surjection and an injection"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "proposition",
      "label": "Induced surjection onto range",
      "anchor": {
        "section": "Induced surjection and induced bijection",
        "snippet": "Any function induces a surjection by restricting its codomain to its range"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "theorem",
      "label": "Induced bijection on a quotient",
      "anchor": {
        "section": "Induced surjection and induced bijection",
        "snippet": "Any surjective function induces a bijection defined on a quotient of its domain"
      },
      "provenance": "ai-agent1"
    },
    {
      "kind": "proposition",
      "label": "Number of surjections (Twelvefold way)",
      "anchor": {
        "section": "The set of surjections",
        "snippet": "The cardinality of this set is one of the twelve aspects of Rota's Twelvefold way"
      },
      "provenance": "ai-agent1"
    }
  ]
