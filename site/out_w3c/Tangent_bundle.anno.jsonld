        },
        {
          "type": "TextualBody",
          "purpose": "describing",
          "value": "`TangentSpace.vectorBundle` gives `VectorBundle 𝕜 E (TangentSpace I)`, with fiber the model space `E` and transition functions the Jacobian derivatives of coordinate changes (`tangentBundleCore.coordChange = fderivWithin ...`), matching the rank-n (= dim E) vector bundle with Jacobian transitions.",
          "format": "text/plain"
        }
