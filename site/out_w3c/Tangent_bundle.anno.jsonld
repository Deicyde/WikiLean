        {
          "type": "TextualBody",
          "purpose": "describing",
          "value": "`TangentBundle I M` is defined as `Bundle.TotalSpace E (TangentSpace I : M → Type _)`, i.e. the sigma-type / disjoint union of the tangent spaces `TangentSpace I x` (each a type synonym for the model space `E`).",
          "format": "text/plain"
        }
      ],
      "target": {
        "source": "https://en.wikipedia.org/wiki/Tangent_bundle?oldid=1351233929",
        "selector": {
          "type": "TextQuoteSelector",
          "exact": "the tangent bundle of a differentiable manifold",
          "prefix": "lly, in differential geometry , ",
          "suffix": " is a manifold which assembles a"
        }
      }
    },
