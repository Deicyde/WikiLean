        {
          "type": "TextualBody",
          "purpose": "describing",
          "value": "Mathlib has `instance : LieGroup (𝓡 1) ω Circle` (Mathlib.Geometry.Manifold.Instances.Sphere), and a general fact that Lie groups have trivial tangent bundles would follow from the Lie-algebra trivialization, but neither the trivialization of `TM` for a Lie group nor triviality of the circle's tangent bundle is stated.",
          "format": "text/plain"
        }
      ],
      "target": {
        "source": "https://en.wikipedia.org/wiki/Tangent_bundle?oldid=1351233929",
        "selector": {
