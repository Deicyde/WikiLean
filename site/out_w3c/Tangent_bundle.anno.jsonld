        },
        {
          "type": "TextualBody",
          "purpose": "describing",
          "value": "Local/within-a-set vector field notions appear (e.g. `mlieBracketWithin` for vector fields on a set), and local frames (`IsLocalFrameOn`) exist, but there is no `StructureSheaf`/sheaf-of-vector-fields object assembling local sections into a sheaf.",
          "format": "text/plain"
        }
      ],
