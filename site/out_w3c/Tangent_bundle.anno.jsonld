        {
          "type": "TextualBody",
          "purpose": "tagging",
          "value": "definition"
        },
        {
          "type": "TextualBody",
          "purpose": "describing",
          "value": "No notion of framed manifold or stable triviality of a bundle in Mathlib. `Mathlib.Geometry.Manifold.Bordism` exists but does not define framings or stably-trivial tangent bundles.",
          "format": "text/plain"
        }
      ],
      "target": {
        "source": "https://en.wikipedia.org/wiki/Tangent_bundle?oldid=1351233929",
        "selector": {
          "type": "TextQuoteSelector",
          "exact": "is framed if and only if the tangent bundle",
          "prefix": "ial . By definition, a manifold ",
          "suffix": " is stably trivial, meaning that"
