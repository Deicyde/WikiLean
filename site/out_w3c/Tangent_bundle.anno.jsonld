          "purpose": "linking",
          "source": "https://leanprover-community.github.io/mathlib4_docs/Mathlib/Topology/FiberBundle/Constructions.html#Bundle.Trivial",
          "identifier": "Bundle.Trivial"
        },
        {
          "type": "TextualBody",
