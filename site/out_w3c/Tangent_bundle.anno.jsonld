        {
          "type": "TextualBody",
          "purpose": "tagging",
          "value": "definition"
        },
        {
          "type": "TextualBody",
          "purpose": "describing",
          "value": "`ContMDiffSection.instModule` gives the module structure of sections over the scalar field `𝕜` (with scalar multiplication by `C^n` functions `ψ • s` also defined). The module structure over the full algebra `C^∞(M, 𝕜)` of smooth functions is not registered as an instance, so only the field-module structure is formalized.",
          "format": "text/plain"
        }
      ],
      "target": {
        "source": "https://en.wikipedia.org/wiki/Tangent_bundle?oldid=1351233929",
        "selector": {
          "type": "TextQuoteSelector",
          "exact": "takes on the structure of a module over the commutative algebra",
          "prefix": "e set of all vector fields then ",
          "suffix": " of smooth functions on M , deno"
        }
      }
    },
