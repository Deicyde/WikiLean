        {
          "type": "TextualBody",
          "purpose": "tagging",
          "value": "definition"
        },
        {
          "type": "TextualBody",
          "purpose": "describing",
          "value": "`Bundle.Trivial B F` is the trivial bundle (with `Bundle.Trivial.fiberBundle`/`vectorBundle` instances), but Mathlib has no predicate asserting that a *given* bundle (e.g. a particular `TangentBundle I M`) is isomorphic to a trivial one, so 'the tangent bundle is trivial' is not directly expressible.",
          "format": "text/plain"
        }
      ],
      "target": {
        "source": "https://en.wikipedia.org/wiki/Tangent_bundle?oldid=1351233929",
        "selector": {
          "type": "TextQuoteSelector",
          "exact": "then the tangent bundle is said to be trivial",
          "prefix": "fold . When it is of the form , ",
          "suffix": " . Trivial tangent bundles usual"
        }
