        },
        {
          "type": "TextualBody",
          "purpose": "describing",
          "value": "Not formalized. The tangent bundle is locally trivial over chart domains (`trivializationAt`), but there is no result that over a contractible open set it is diffeomorphic to a product (which would require triviality of bundles over contractible bases).",
          "format": "text/plain"
        }
      ],
      "target": {
        "source": "https://en.wikipedia.org/wiki/Tangent_bundle?oldid=1351233929",
        "selector": {
          "type": "TextQuoteSelector",
          "exact": "is an open contractible subset of",
          "prefix": "n -dimensional vector space. If ",
          "suffix": " , then there is a diffeomorphis"
