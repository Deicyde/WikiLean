        {
          "type": "TextualBody",
          "purpose": "describing",
          "value": "Mathlib defines `Ideal.IsPrime I` as `I ≠ ⊤ ∧ ∀ {x y}, x * y ∈ I → x ∈ I ∨ y ∈ I`, exactly matching the standard prime-ideal concept this informal sentence describes.",
          "format": "text/plain"
        }
      ],
      "target": {
        "source": "https://en.wikipedia.org/wiki/Prime_ideal?oldid=1356076440",
        "selector": {
          "type": "TextQuoteSelector",
          "exact": "a prime ideal is a subset of a ring that shares many important properties of a prime number",
          "prefix": "In algebra , ",
          "suffix": " in the ring of integers . [ 1 ]"
        }
      }
    },
    {
