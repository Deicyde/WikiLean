      },
      "body": [
        {
          "type": "SpecificResource",
          "purpose": "linking",
          "source": "https://leanprover-community.github.io/mathlib4_docs/Mathlib/Topology/MetricSpace/Contracting.html#ContractingWith",
          "identifier": "ContractingWith"
        },
        {
          "type": "TextualBody",
          "purpose": "classifying",
          "value": "formalized"
        },
        {
          "type": "TextualBody",
          "purpose": "classifying",
          "value": "match_kind:exact"
        },
        {
          "type": "TextualBody",
          "purpose": "tagging",
          "value": "definition"
        },
        {
          "type": "TextualBody",
          "purpose": "describing",
          "value": "`ContractingWith K f := K < 1 ∧ LipschitzWith K f` on an `EMetricSpace`; combined with `LipschitzWith` from `Mathlib.Topology.EMetricSpace.Lipschitz` it captures the article's `d(T(x),T(y)) ≤ q·d(x,y)` with `q < 1`.",
          "format": "text/plain"
        }
      ],
      "target": {
        "source": "https://en.wikipedia.org/wiki/Banach_fixed-point_theorem?oldid=1350866762",
        "selector": {
          "type": "TextQuoteSelector",
          "exact": "is called a contraction mapping on"
        }
      }
    },
    {
      "id": "urn:wikilean:Banach_fixed-point_theorem:anno-1",
      "type": "Annotation",
      "motivation": "linking",
      "created": "2026-05-27T20:01:57+00:00",
      "generator": {
        "type": "Software",
        "name": "WikiLean 2-agent annotation pipeline",
        "homepage": "https://github.com/Deicyde/WikiLean"
      },
      "body": [
        {
          "type": "SpecificResource",
          "purpose": "linking",
          "source": "https://leanprover-community.github.io/mathlib4_docs/Mathlib/Topology/MetricSpace/Contracting.html#ContractingWith.exists_fixedPoint",
          "identifier": "ContractingWith.exists_fixedPoint"
        },
        {
          "type": "TextualBody",
          "purpose": "classifying",
          "value": "formalized"
        },
        {
          "type": "TextualBody",
          "purpose": "classifying",
          "value": "match_kind:exact"
        },
        {
          "type": "TextualBody",
          "purpose": "tagging",
          "value": "proposition"
        },
        {
          "type": "TextualBody",
          "purpose": "describing",
          "value": "`exists_fixedPoint` packages existence, uniqueness (via `fixedPoint_unique`) and the iteration convergence `Tendsto (fun n ↦ f^[n] x) atTop (𝓝 y)` — exactly the article's three conclusions. The unique fixed point itself is `ContractingWith.fixedPoint`.",
          "format": "text/plain"
        }
      ],
      "target": {
        "source": "https://en.wikipedia.org/wiki/Banach_fixed-point_theorem?oldid=1350866762",
        "selector": {
          "type": "TextQuoteSelector",
          "exact": "admits a unique fixed point"
        }
      }
    },
    {
      "id": "urn:wikilean:Banach_fixed-point_theorem:anno-3",
      "type": "Annotation",
      "motivation": "linking",
      "created": "2026-05-27T20:01:57+00:00",
      "generator": {
        "type": "Software",
        "name": "WikiLean 2-agent annotation pipeline",
        "homepage": "https://github.com/Deicyde/WikiLean"
      },
      "body": [
        {
          "type": "SpecificResource",
          "purpose": "linking",
          "source": "https://leanprover-community.github.io/mathlib4_docs/Mathlib/Topology/EMetricSpace/Lipschitz.html#LipschitzWith",
          "identifier": "LipschitzWith"
        },
        {
          "type": "TextualBody",
          "purpose": "classifying",
          "value": "formalized"
        },
        {
          "type": "TextualBody",
          "purpose": "classifying",
          "value": "match_kind:exact"
        },
        {
          "type": "TextualBody",
          "purpose": "tagging",
          "value": "definition"
        },
        {
          "type": "TextualBody",
          "purpose": "describing",
          "value": "`LipschitzWith K f := ∀ x y, edist (f x) (f y) ≤ K · edist x y`; the article's `q` is the `K` parameter.",
          "format": "text/plain"
        }
      ],
      "target": {
        "source": "https://en.wikipedia.org/wiki/Banach_fixed-point_theorem?oldid=1350866762",
        "selector": {
          "type": "TextQuoteSelector",
          "exact": "Lipschitz constant"
        }
      }
    },
    {
      "id": "urn:wikilean:Banach_fixed-point_theorem:anno-4",
      "type": "Annotation",
      "motivation": "classifying",
      "created": "2026-05-27T20:01:57+00:00",
      "generator": {
        "type": "Software",
        "name": "WikiLean 2-agent annotation pipeline",
        "homepage": "https://github.com/Deicyde/WikiLean"
      },
      "body": [
        {
          "type": "TextualBody",
          "purpose": "classifying",
          "value": "not_formalized"
        },
        {
          "type": "TextualBody",
          "purpose": "tagging",
          "value": "example"
        },
        {
          "type": "TextualBody",
          "purpose": "describing",
          "value": "Mathlib has no formalization of this specific counter-example showing that `d(T(x),T(y))<d(x,y)` alone (without a uniform `q<1`) is insufficient.",
          "format": "text/plain"
        }
      ],
      "target": {
        "source": "https://en.wikipedia.org/wiki/Banach_fixed-point_theorem?oldid=1350866762",
        "selector": {
          "type": "TextQuoteSelector",
          "exact": "is in general not enough to ensure the existence of a fixed point"
        }
      }
    },
    {
      "id": "urn:wikilean:Banach_fixed-point_theorem:anno-5",
      "type": "Annotation",
      "motivation": "classifying",
      "created": "2026-05-27T20:01:57+00:00",
      "generator": {
        "type": "Software",
        "name": "WikiLean 2-agent annotation pipeline",
        "homepage": "https://github.com/Deicyde/WikiLean"
      },
      "body": [
        {
          "type": "TextualBody",
          "purpose": "classifying",
          "value": "not_formalized"
        },
        {
          "type": "TextualBody",
          "purpose": "tagging",
          "value": "proposition"
        },
        {
          "type": "TextualBody",
          "purpose": "describing",
          "value": "Edelstein's theorem: on a compact metric space, any map satisfying d(T(x),T(y))<d(x,y) for all distinct x,y has a unique fixed point. No matching decl in Mathlib's `Mathlib/Topology/MetricSpace/Contracting.lean` or elsewhere.",
          "format": "text/plain"
        }
      ],
      "target": {
        "source": "https://en.wikipedia.org/wiki/Banach_fixed-point_theorem?oldid=1350866762",
        "selector": {
          "type": "TextQuoteSelector",
          "exact": "In a non-empty compact metric space"
        }
      }
    },
    {
      "id": "urn:wikilean:Banach_fixed-point_theorem:anno-6",
      "type": "Annotation",
