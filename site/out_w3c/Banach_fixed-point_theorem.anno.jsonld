    {
      "id": "urn:wikilean:Banach_fixed-point_theorem:anno-11",
      "type": "Annotation",
      "motivation": "classifying",
      "created": "2026-05-27T20:01:57+00:00",
      "generator": {
        "type": "Software",
        "name": "WikiLean 2-agent annotation pipeline",
        "homepage": "https://github.com/Deicyde/WikiLean"
      },
      "body": [
        {
          "type": "TextualBody",
          "purpose": "classifying",
          "value": "not_formalized"
        },
        {
          "type": "TextualBody",
          "purpose": "tagging",
          "value": "proposition"
        },
        {
          "type": "TextualBody",
          "purpose": "describing",
          "value": "Bessaga (1959): if every iterate `f^n` of a set self-map has a unique fixed point, then for any `q ∈ (0,1)` there is a complete metric making `f` a `q`-contraction. No such metric-construction lemma exists in Mathlib.",
          "format": "text/plain"
        }
      ],
      "target": {
        "source": "https://en.wikipedia.org/wiki/Banach_fixed-point_theorem?oldid=1350866762",
        "selector": {
          "type": "TextQuoteSelector",
          "exact": "each iterate"
        }
      }
    },
    {
      "id": "urn:wikilean:Banach_fixed-point_theorem:anno-12",
      "type": "Annotation",
      "motivation": "classifying",
      "created": "2026-05-27T20:01:57+00:00",
      "generator": {
        "type": "Software",
        "name": "WikiLean 2-agent annotation pipeline",
        "homepage": "https://github.com/Deicyde/WikiLean"
      },
      "body": [
        {
          "type": "TextualBody",
          "purpose": "classifying",
          "value": "not_formalized"
        },
        {
          "type": "TextualBody",
          "purpose": "tagging",
          "value": "proposition"
        },
        {
          "type": "TextualBody",
          "purpose": "describing",
          "value": "Hitzler–Seda: for a T₁ self-map with unique fixed point that every orbit converges to, an ultrametric exists making it a `1/2`-contraction. Not in Mathlib.",
          "format": "text/plain"
        }
      ],
      "target": {
        "source": "https://en.wikipedia.org/wiki/Banach_fixed-point_theorem?oldid=1350866762",
        "selector": {
          "type": "TextQuoteSelector",
          "exact": "very weak assumptions suffice to obtain such a kind of converse"
        }
      }
    },
