      "body": [
        {
          "type": "SpecificResource",
          "purpose": "linking",
          "source": "https://leanprover-community.github.io/mathlib4_docs/Mathlib/Topology/MetricSpace/Contracting.html#ContractingWith.isFixedPt_fixedPoint_iterate",
          "identifier": "ContractingWith.isFixedPt_fixedPoint_iterate"
        },
        {
          "type": "TextualBody",
          "purpose": "classifying",
          "value": "formalized"
        },
        {
          "type": "TextualBody",
          "purpose": "classifying",
          "value": "match_kind:exact"
        },
        {
          "type": "TextualBody",
          "purpose": "tagging",
          "value": "proposition"
        },
        {
          "type": "TextualBody",
          "purpose": "describing",
          "value": "If `f^[n]` is `ContractingWith K`, then the (unique) fixed point of `f^[n]` is also a fixed point of `f`; combined with `fixedPoint_unique` this yields existence+uniqueness for `f` itself.",
          "format": "text/plain"
        }
      ],
      "target": {
        "source": "https://en.wikipedia.org/wiki/Banach_fixed-point_theorem?oldid=1350866762",
        "selector": {
          "type": "TextQuoteSelector",
          "exact": "Assume that some iterate"
        }
      }
    },
