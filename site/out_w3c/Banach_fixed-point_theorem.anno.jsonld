          "value": "proposition"
        },
        {
          "type": "TextualBody",
          "purpose": "describing",
          "value": "The inverse function theorem in Banach spaces, proved via `ApproximatesLinearOn` (which is itself a Banach-fixed-point argument).",
          "format": "text/plain"
        }
      ],
      "target": {
