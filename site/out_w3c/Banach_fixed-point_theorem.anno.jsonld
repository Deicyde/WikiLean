        },
        {
          "type": "TextualBody",
          "purpose": "describing",
          "value": "The Nash embedding theorem (every Riemannian manifold can be isometrically embedded into Euclidean space) is not formalized in Mathlib.",
          "format": "text/plain"
        }
      ],
      "target": {
