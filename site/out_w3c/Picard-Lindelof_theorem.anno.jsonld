        },
        {
          "type": "TextualBody",
          "purpose": "describing",
          "value": "Mathlib bundles the rectangle/Lipschitz/continuity hypotheses into `IsPicardLindelof` and concludes existence of a solution α with HasDerivWithinAt on `Icc tmin tmax`. Uniqueness is the companion theorem `ODE_solution_unique` in `Mathlib.Analysis.ODE.Gronwall`.",
          "format": "text/plain"
        }
      ],
      "target": {
        "source": "https://en.wikipedia.org/wiki/Picard%E2%80%93Lindel%C3%B6f_theorem?oldid=1346301030",
        "selector": {
          "type": "TextQuoteSelector",
          "exact": "Then there exists some"
        }
      }
    },
