          "value": "not_formalized"
        },
        {
          "type": "TextualBody",
          "purpose": "tagging",
          "value": "definition"
        },
        {
          "type": "TextualBody",
          "purpose": "describing",
          "value": "Mathlib does not model decimal floating-point computer arithmetic systems.",
          "format": "text/plain"
        }
      ],
      "target": {
        "source": "https://en.wikipedia.org/wiki/Scientific_notation?oldid=1351915575",
        "selector": {
          "type": "TextQuoteSelector",
          "exact": "Decimal floating point is a computer arithmetic system",
          "prefix": "is at least 1 but less than 10. ",
          "suffix": " closely related to scientific n"
        }
      }
    },
    {
      "id": "urn:wikilean:Scientific_notation:anno-3",
