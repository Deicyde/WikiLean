          "value": "partial"
        },
        {
          "type": "TextualBody",
          "purpose": "tagging",
          "value": "definition"
        },
        {
          "type": "TextualBody",
          "purpose": "describing",
          "value": "Lean/Mathlib's `OfScientific.ofScientific` literal machinery (m × 10^±e) implements scientific notation, but there is no general mathematical definition of the concept.",
          "format": "text/plain"
        }
      ],
      "target": {
        "source": "https://en.wikipedia.org/wiki/Scientific_notation?oldid=1351915575",
        "selector": {
          "type": "TextQuoteSelector",
          "exact": "Scientific notation is a way of expressing numbers",
          "suffix": " that are too large or too small"
        }
      }
    },
    {
      "id": "urn:wikilean:Scientific_notation:anno-1",
      "type": "Annotation",
      "motivation": "linking",
      "created": "2026-05-28T05:07:35+00:00",
      "generator": {
        "type": "Software",
        "name": "WikiLean 2-agent annotation pipeline",
        "homepage": "https://github.com/Deicyde/WikiLean"
      },
      "body": [
        {
          "type": "SpecificResource",
          "purpose": "linking",
          "source": "https://leanprover-community.github.io/mathlib4_docs/Mathlib/Algebra/Field/Defs.html#Rat.ofScientific_eq_ofScientific",
          "identifier": "Rat.ofScientific_eq_ofScientific"
        },
        {
          "type": "TextualBody",
          "purpose": "classifying",
          "value": "partial"
        },
        {
          "type": "TextualBody",
          "purpose": "tagging",
          "value": "definition"
        },
        {
          "type": "TextualBody",
          "purpose": "describing",
          "value": "`OfScientific.ofScientific` takes a mantissa `m`, sign `s`, and exponent `e`, but the significand/exponent terminology is not separately formalized.",
          "format": "text/plain"
        }
      ],
      "target": {
        "source": "https://en.wikipedia.org/wiki/Scientific_notation?oldid=1351915575",
        "selector": {
          "type": "TextQuoteSelector",
          "exact": "The integer n is called the exponent and the real number m is called the significand",
          "prefix": "ten as a terminating decimal ). ",
          "suffix": " or mantissa . [ 1 ] The term \"m"
        }
      }
    },
    {
      "id": "urn:wikilean:Scientific_notation:anno-2",
      "type": "Annotation",
      "motivation": "classifying",
      "created": "2026-05-28T05:07:35+00:00",
