        {
          "type": "TextualBody",
          "purpose": "classifying",
          "value": "partial"
        },
        {
          "type": "TextualBody",
          "purpose": "tagging",
          "value": "proposition"
        },
        {
          "type": "TextualBody",
          "purpose": "describing",
          "value": "`Int.log` plus its bounds `Int.zpow_log_le_self`/`Int.lt_zpow_succ_log_self` provide the exponent placing any positive real in [b^n, b^(n+1)), but no explicit `r = m·10^n` decomposition lemma is stated.",
          "format": "text/plain"
        }
      ],
      "target": {
        "source": "https://en.wikipedia.org/wiki/Scientific_notation?oldid=1351915575",
        "selector": {
          "type": "TextQuoteSelector",
          "exact": "Any real number can be written in the form",
          "prefix": " tool. See Slide rule#History . ",
          "suffix": " m × 10 ^ n in many ways: for ex"
        }
      }
    },
    {
      "id": "urn:wikilean:Scientific_notation:anno-4",
      "type": "Annotation",
      "motivation": "linking",
      "created": "2026-05-28T05:07:35+00:00",
      "generator": {
        "type": "Software",
