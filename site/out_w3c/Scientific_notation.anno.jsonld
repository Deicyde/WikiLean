        },
        {
          "type": "TextualBody",
          "purpose": "tagging",
          "value": "proposition"
        },
        {
          "type": "TextualBody",
          "purpose": "describing",
          "value": "`Int.log_of_right_le_one` shows `log b r = -Nat.clog b ⌈r⁻¹⌉₊ ≤ 0` for r ≤ 1, matching the negative-exponent claim, though stated about `Int.log` rather than scientific notation.",
          "format": "text/plain"
        }
      ],
      "target": {
        "source": "https://en.wikipedia.org/wiki/Scientific_notation?oldid=1351915575",
        "selector": {
          "type": "TextQuoteSelector",
          "exact": "the exponent n is negative for a number with absolute value between 0 and 1",
          "prefix": "ithms . In normalized notation, ",
          "suffix": " (e.g. 0.5 is written as 5 × 10 "
        }
      }
    },
