      "body": [
        {
          "type": "SpecificResource",
          "purpose": "linking",
          "source": "https://leanprover-community.github.io/mathlib4_docs/Mathlib/Data/Int/Log.html#Int.zpow_log_le_self",
          "identifier": "Int.zpow_log_le_self"
