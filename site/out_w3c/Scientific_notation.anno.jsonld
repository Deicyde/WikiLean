        "homepage": "https://github.com/Deicyde/WikiLean"
      },
      "body": [
        {
          "type": "SpecificResource",
          "purpose": "linking",
          "source": "https://leanprover-community.github.io/mathlib4_docs/Mathlib/Data/Int/Log.html#Int.lt_zpow_succ_log_self",
          "identifier": "Int.lt_zpow_succ_log_self"
        },
        {
          "type": "TextualBody",
          "purpose": "classifying",
          "value": "partial"
        },
        {
          "type": "TextualBody",
          "purpose": "tagging",
          "value": "definition"
        },
        {
          "type": "TextualBody",
          "purpose": "describing",
          "value": "`Int.log b r` is exactly the normalizing exponent, with `Int.zpow_log_le_self`/`Int.lt_zpow_succ_log_self` giving b^log ≤ r < b^(log+1) (i.e. 1 ≤ r/b^log < b), but the normalized-form definition itself is not packaged.",
          "format": "text/plain"
        }
      ],
      "target": {
        "source": "https://en.wikipedia.org/wiki/Scientific_notation?oldid=1351915575",
        "selector": {
          "type": "TextQuoteSelector",
          "exact": "the exponent n is chosen so that the absolute value of m remains at least one and less than ten",
          "prefix": "d form\" in the United Kingdom), ",
          "suffix": " ( 1 ≤ | m | < 10 ). Thus 350 is"
        }
      }
    },
    {
      "id": "urn:wikilean:Scientific_notation:anno-5",
